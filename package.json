{
  "name": "personal-budget",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:server": "npm run dev -w packages/server",
    "dev:client": "npm run dev -w packages/client",
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm run build -w packages/shared",
    "build:server": "npm run build -w packages/server",
    "build:client": "npm run build -w packages/client",
    "db:generate": "npm run db:generate -w packages/server",
    "db:push": "npm run db:push -w packages/server",
    "db:migrate": "npm run db:migrate -w packages/server",
    "db:seed": "npm run db:seed -w packages/server",
    "vercel-build": "rm -rf packages/shared/dist packages/client/dist && npm run build:shared && npm run build:client"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
