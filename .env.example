# Database
DATABASE_URL="postgresql://user:password@localhost:5432/personal_budget?schema=public"

# JWT
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV="development"

# Client
VITE_API_URL="http://localhost:3001/api"

# Open Food Facts (no key needed, but configurable base URL)
OFF_API_URL="https://world.openfoodfacts.org/api/v2"

# Exchange Rates
EXCHANGE_RATE_API_URL="https://api.frankfurter.app"
